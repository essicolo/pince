{
    "app-id": "io.github.essicolo.Pince",
    "runtime": "org.gnome.Platform",
    "runtime-version": "46",
    "sdk": "org.gnome.Sdk",
    "command": "pince",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",

        "// Network: used ONLY for CrossRef DOI lookups (api.crossref.org)",
        "// Only triggered by explicit user action (Fetch Metadata button)",
        "// No data is sent except the DOI string. No tracking, no accounts.",
        "--share=network",

        "// Filesystem: read-only access to home for opening documents",
        "// Documents are never moved/copied — Pince only reads them",
        "--filesystem=home:ro",
        "--filesystem=xdg-documents"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/pkgconfig",
        "/share/vala",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "blueprint-compiler",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
                    "tag": "v0.14.0"
                }
            ]
        },
        {
            "name": "libgee",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/GNOME/libgee.git",
                    "tag": "0.20.6"
                }
            ]
        },
        {
            "name": "poppler",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DENABLE_QT5=OFF",
                "-DENABLE_QT6=OFF",
                "-DENABLE_CPP=OFF",
                "-DENABLE_BOOST=OFF",
                "-DENABLE_GOBJECT_INTROSPECTION=ON",
                "-DENABLE_GLIB=ON"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.freedesktop.org/poppler/poppler.git",
                    "tag": "poppler-24.04.0"
                }
            ]
        },
        {
            "name": "pince",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
